{
  "generatorOptions": {
    "pageName": "custom-{slug}",
    "source": "custom",
    "map": {
      "PRODUCT_NAME": "$data.name",
      "PRODUCT_PRICE": "$data.price",
      "PRODUCT_DESCRIPTION": "$data.description",
      "PRODUCT_DETAILS": "$data.details"
    }
  },
  "layout": "_layout",
  "header_theme": "dark",
  "components": [
    { "name": "carousel", "vars": { "IMAGES": "$images", "ALT": "$data.name" } },
    { "name": "contactIcons" }
  ]
}
